# ─────────────────────────────────────────────────────────────────────────────
# Plantilla de variables de entorno.  EN EL NOTEBOOK:  cp .env.example .env
# y rellena los valores reales.  NUNCA subas el .env a Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App / público (se incrustan en el build, NEXT_PUBLIC_*) ──────────────────
# Solo se usa para las llamadas internas del servidor a sí mismo (/api/proxy).
# DÉJALO en localhost:3000 — NO es la URL pública del túnel (esa la usa el navegador
# con rutas relativas, así que la URL aleatoria del quick tunnel no afecta).
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Modo manual del front. PAUSADO por defecto (no dispara descargas/IA solo).
# Para REACTIVAR la automatización: poner explícitamente 0 (o false). Cualquier
# otro valor (ausente, 1, true) = pausado.
NEXT_PUBLIC_AUTOMATIZACION_PAUSADA=1
# NOTA: NO existe NEXT_PUBLIC_CRON_SECRET. El disparo manual del cron va por
# /api/radar/actualizar (protegido por sesión admin); el CRON_SECRET vive SOLO
# en el servidor y nunca debe incrustarse en el bundle del navegador.

# ── Base de datos (Bluehost MySQL) ───────────────────────────────────────────
DB_HOST=tu-host-mysql.bluehost.com
DB_PORT=3306
DB_USER=tu_usuario
DB_PASSWORD=tu_password
DB_NAME=tu_base_de_datos

# ── Cloudflare R2 (almacenamiento de documentos) ─────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://tu-bucket-publico.r2.dev

# ── Mercado Público ──────────────────────────────────────────────────────────
# Ticket de la API oficial de datos abiertos (api.mercadopublico.cl).
MERCADO_PUBLICO_TICKET=

# ── IA ───────────────────────────────────────────────────────────────────────
# getGemini() apunta a DeepSeek → esta key es la de DeepSeek.
DEEPSEEK_API_KEY=
# Habilita el pipeline IA tras la descarga (clasificación/análisis/viabilidad).
GEMINI_API_KEY=
# OCR de respaldo para PDFs escaneados (opcional).
OCRSPACE_API_KEY=
# Valor de la UTM vigente en CLP (referencial para el gate de presupuesto por tipo
# cuando la licitación no publica monto). Actualízalo cada mes. Default: 69000.
UTM_CLP=69000

# ── Seguridad / secretos ─────────────────────────────────────────────────────
# Firma de sesiones (JWT). Pon una cadena larga y aleatoria.
JWT_SECRET=
# Protege el endpoint /api/cron/alertas (lo usa cron-job.org). Igual a NEXT_PUBLIC_CRON_SECRET.
CRON_SECRET=pon-un-secreto-largo-igual-a-NEXT_PUBLIC_CRON_SECRET
# Protege los endpoints de migración de BD (opcional).
MIGRATION_SECRET=

# ── Redis (Upstash) — rate limiting ──────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Con QUICK TUNNEL (gratis, sin dominio) NO se necesita token: déjalo vacío.
# Solo se usa si algún día migras a un túnel con nombre + dominio propio.
CLOUDFLARE_TUNNEL_TOKEN=
