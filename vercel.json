{
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/alertas",
      "schedule": "0 */6 * * *"
    }
  ],
  "functions": {
    "app/api/analizar-documento/route.ts": {
      "maxDuration": 60
    },
    "app/api/search/route.ts": {
      "maxDuration": 30
    },
    "app/api/documentos/auto-descargar/route.ts": {
      "maxDuration": 60
    },
    "app/api/documentos/[codigo]/route.ts": {
      "maxDuration": 30
    },
    "app/api/proxy/route.ts": {
      "maxDuration": 30
    },
    "app/api/cron/alertas/route.ts": {
      "maxDuration": 60
    }
  },
  "env": {
    "PUPPETEER_SKIP_CHROMIUM_DOWNLOAD": "true"
  }
}
