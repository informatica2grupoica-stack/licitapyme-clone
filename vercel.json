      "maxDuration": 30
    },
    "app/api/proxy/route.ts": {
      "maxDuration": 30
    },
    "app/api/cron/alertas/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/enriquecer/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/prefiltro/route.ts": {
      "maxDuration": 60
    }
